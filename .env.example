# Copy to .env to enable the real backends. Without these, the app runs fully
# in guest mode (localStorage) with a mock checkout — no setup required.

# Supabase (Auth + Postgres + Realtime leaderboard)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe (Embedded Checkout)
VITE_STRIPE_PUBLISHABLE_KEY=
